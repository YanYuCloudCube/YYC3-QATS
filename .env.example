# ═══════════════════════════════════════════════════════════
# YYC3-QATS Environment Variables Template
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Development API ──
VITE_YYC_API_DEV_BASE=http://localhost:3200
VITE_YYC_WS_DEV_URL=ws://localhost:3200/ws
VITE_YYC_API_DEV_HEALTH=http://localhost:3200/health

# ── Test API ──
VITE_YYC_API_TEST_BASE=https://test-api.0379.world
VITE_YYC_WS_TEST_URL=wss://test-api.0379.world/ws
VITE_YYC_API_TEST_HEALTH=https://test-api.0379.world/health

# ── Production API ──
VITE_YYC_API_PROD_BASE=https://api.0379.world
VITE_YYC_WS_PROD_URL=wss://api.0379.world/ws
VITE_YYC_API_PROD_HEALTH=https://api.0379.world/health
VITE_YYC_API_PROD_DOMAIN=0379.world

# ── HTTP Timeouts (ms) ──
VITE_YYC_HTTP_TIMEOUT_DEV=10000
VITE_YYC_HTTP_TIMEOUT_TEST=15000
VITE_YYC_HTTP_TIMEOUT_PROD=15000

# ── WebSocket Settings (ms) ──
VITE_YYC_WS_HEARTBEAT_DEV=30000
VITE_YYC_WS_HEARTBEAT_TEST=30000
VITE_YYC_WS_HEARTBEAT_PROD=25000
VITE_YYC_WS_RECONNECT_DELAY_DEV=3000
VITE_YYC_WS_RECONNECT_DELAY_TEST=5000
VITE_YYC_WS_RECONNECT_DELAY_PROD=5000
